            Fluent:Notify({
                Title = "🎣 Auto Farm",
                Content = "Đã bật! Đang tự động câu & canh Perfect...",
                Duration = 3
            })
            task.spawn(runAutoFarm)
        else
            Fluent:Notify({
                Title = "Auto Farm",
                Content = "Đã tắt.",
                Duration = 2
            })
        end
    end
})

