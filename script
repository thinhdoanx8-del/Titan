            Fluent:Notify({
                Title = "Auto Farm",
                Content = "Đã bật! Đang câu cá & canh Perfect...",
                Duration = 3
            })
            task.spawn(runAutoFarm)
        else
            Fluent:Notify({
                Title = "Auto Farm",
                Content = "Đã tắt Auto Farm.",
                Duration = 2
            })
        end
    end
})

