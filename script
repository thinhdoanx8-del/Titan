-- ============================================
-- HÀM TAP
-- ============================================
local function tapAt(x, y)
    pcall(function()
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)  -- giữ chuột một chút
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

-- ============================================
-- VÒNG LẶP AUTO FARM (TAP LIÊN TỤC)
-- ============================================
local function runAutoFarm()
    while autoFarmOn do
        tapAt(BTN_X + offsetX, BTN_Y + offsetY)
        task.wait(clickSpeed)  -- tốc độ tap do người dùng cài
    end
end

-- ============================================
-- HÀM SKILL (giữ nguyên)
-- ============================================
local function pressSkill(skillName)
    for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if obj.Name == skillName and obj.Parent.Name == "Skills" then
            pcall(function() firesignal(obj.MouseButton1Click) end)
            pcall(function() firesignal(obj.Activated) end)
            pcall(function() firesignal(obj.TouchTap) end)
            pcall(function()
                firesignal(obj.MouseButton1Down, 0, 0)
                task.wait(0.05)
                firesignal(obj.MouseButton1Up, 0, 0)
            end)
            break
        end
    end
end

local function runAutoSkill()
    while autoSkillOn do
        if #selectedKeys == 0 then
            task.wait(0.3)
        else
            for _, skillName in ipairs(selectedKeys) do
                if not autoSkillOn then break end
                pressSkill(skillName)
                task.wait(skillDelay)
            end
        end
    end
end

-- ============================================
-- HÀM AUTO SELL (giữ nguyên)
-- ============================================
local function doSell()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local savedPos = root.CFrame

    local nearestNPC  = nil
    local nearestDist = math.huge
    local nearestPP   = nil

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "bluewaterrobux" and obj:IsA("Model") then
            local part = obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")
            if part then
                local dist = (part.Position - root.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestNPC  = part
                end
            end
        end
    end

    if not nearestNPC then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == "Interact" then
            local part = obj.Parent
            if part:IsA("BasePart") then
                local dist = (part.Position - nearestNPC.Position).Magnitude
                if dist < 15 then
                    nearestPP = obj
                    break
                end
            end
        end
    end

    root.Anchored = true
    local tween = TweenService:Create(root, TweenInfo.new(
        2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out
    ), { CFrame = CFrame.new(nearestNPC.Position + Vector3.new(0, 0, 4)) })
    tween:Play()
    tween.Completed:Wait()
    root.Anchored = false
    task.wait(0.5)

    if nearestPP then fireproximityprompt(nearestPP) end

    task.wait(1)
    for _, obj in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if obj:IsA("TextLabel") and string.lower(obj.Text):find("sell all") then
            local parent = obj.Parent
            pcall(function() firesignal(parent.MouseButton1Click) end)
            pcall(function() firesignal(parent.Activated) end)
            pcall(function()
                firesignal(parent.MouseButton1Down, 0, 0)
                task.wait(0.05)
                firesignal(parent.MouseButton1Up, 0, 0)
            end)
        end
    end

    task.wait(1)
    root.Anchored = true
    local tweenBack = TweenService:Create(root, TweenInfo.new(
        2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out
    ), { CFrame = savedPos })
    tweenBack:Play()
    tweenBack.Completed:Wait()
    root.Anchored = false
end

local function runAutoSell()
    while autoSellOn do
        doSell()
        task.wait(sellInterval)
    end
end

