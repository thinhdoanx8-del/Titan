            })
        else
            WindUI:Notify({
                Title = "Auto Farm TẮT",
                Content = "Đã dừng tap.",
                Duration = 2
            })
        end
    end,
})

-- Hiển thị offset hiện tại
local offsetLabel = TabAutoFarm:Paragraph({
    Title   = "Current Offset:",
    Content = string.format("X Axis: %d | Y Axis: %d", offsetX, offsetY),
})

-- Điều chỉnh offset X
TabAutoFarm:Input({
    Title       = "X Axis Offset",
    Flag        = "XOffset",
    Placeholder = "Ex: 40",
    Callback    = function(val)
        local num = tonumber(val)
        if num then
            offsetX = num
            offsetLabel:Set({ Content = string.format("X Axis: %d | Y Axis: %d", offsetX, offsetY) })
        end
    end,
})

-- Điều chỉnh offset Y
TabAutoFarm:Input({
    Title       = "Y Axis Offset",
    Flag        = "YOffset",
    Placeholder = "Ex: 0",
    Callback    = function(val)
        local num = tonumber(val)
        if num then
            offsetY = num
            offsetLabel:Set({ Content = string.format("X Axis: %d | Y Axis: %d", offsetX, offsetY) })
        end
    end,
})

