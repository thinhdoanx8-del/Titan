-- TAB AUTO SKILL (giữ nguyên)
-- ============================================
TabAutoSkill:Dropdown({
    Title    = "Skill Keys Mobile",
    Flag     = "SkillKeys",
    Values   = { "Z", "X", "C", "V" },
    Default  = {},
    Multi    = true,
    Callback = function(selected)
        selectedKeys = {}
        if type(selected) == "table" then
            for k, v in pairs(selected) do
                if type(k) == "string" and v == true then
                    table.insert(selectedKeys, k)
                elseif type(k) == "number" and type(v) == "string" then
                    table.insert(selectedKeys, v)
                end
            end
        end
    end,
})

TabAutoSkill:Toggle({
    Title    = "Auto Skill Mobile",
    Flag     = "AutoSkill",
    Default  = false,
    Callback = function(state)
        autoSkillOn = state
        if state then task.spawn(runAutoSkill) end
    end,
})

TabAutoSkill:Toggle({
    Title    = "Freeze Character",
    Flag     = "FreezeChar",
    Default  = false,
    Callback = function(state)
        freezeOn = state
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = state and 0 or 16
            hum.JumpPower = state and 0 or 50
        end
    end,
})

